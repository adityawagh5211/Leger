DATABASE_URL=postgresql+psycopg://ledger:ledger@localhost:5432/ledger
AUTH_PROVIDER=dev
SUPABASE_JWKS_URL=
FIREBASE_PROJECT_ID=

# AI Providers — get free keys at:
# Groq: console.groq.com
GROQ_API_KEY=

# Gemini: aistudio.google.com
GEMINI_API_KEY=

# Cohere: dashboard.cohere.com
COHERE_API_KEY=

# Cerebras: cloud.cerebras.ai
CEREBRAS_API_KEY=

# OpenRouter: openrouter.ai
OPENROUTER_API_KEY=

# Mistral (for OCR): console.mistral.ai
MISTRAL_API_KEY=

# ── Embedding Model (local AI categorization) ─────────────────────────────────
# Set to false on servers with < 512 MB RAM (Render free tier, Railway starter).
# The categorization pipeline falls through to rules + LLM automatically.
ENABLE_LOCAL_EMBEDDINGS=true

# Model name — must be a sentence-transformers compatible model on HuggingFace.
# all-MiniLM-L6-v2 is recommended: 90 MB, fast, accurate for short text.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Path where HuggingFace downloads models. Mount this as a persistent volume
# in Docker/Kubernetes to avoid re-downloading on every container restart.
# Defaults to backend/.hf_cache if not set.
# HF_HOME=/data/hf_cache
# TRANSFORMERS_CACHE=/data/hf_cache

# Confidence threshold below which LLM categorization is triggered (0.0–1.0).
CATEGORIZATION_CONFIDENCE_THRESHOLD=0.85
